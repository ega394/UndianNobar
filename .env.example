# ── Supabase (WAJIB) ────────────────────────────────────────────────
# Ambil dari: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# GUNAKAN service_role key (rahasia, HANYA dipakai di serverless function,
# tidak pernah dikirim ke browser). JANGAN pakai anon key di sini.
SUPABASE_SERVICE_KEY=eyJhbGciOi...service_role...

# ── Kunci token login panitia (WAJIB) ───────────────────────────────
# Hanya dipakai untuk menandatangani token sesi login panitia (bukan data).
# Mengubahnya hanya membuat panitia perlu login ulang — tidak memengaruhi data.
# Buat string acak panjang (min 32 karakter), contoh:  openssl rand -hex 32
DATA_SECRET=ganti-dengan-string-acak-panjang-min-32-karakter

# ── Password panel panitia (WAJIB) ──────────────────────────────────
# Password bersama untuk login panel panitia di /panitia
PANITIA_PASSWORD=ganti-password-panitia
